<section class="my-vault">
  {% assign comics_collection = collections['comics'] %}
  {% assign has_vault_access = false %}

  {% if customer and customer.tags contains 'vault_unlocked' %}
    {% assign has_vault_access = true %}
  {% endif %}

  <div class="my-vault__inner page-width">
    {% if customer == blank %}
      <header class="my-vault__hero">
        <span class="my-vault__kicker">Digital Library</span>
        <h1 class="my-vault__title">My Vault</h1>
        <p class="my-vault__intro">
          Sign in to access your library, continue reading, or unlock the full collection.
        </p>

        <div class="my-vault__actions">
          <a href="{{ routes.account_login_url }}" class="my-vault__button my-vault__button--primary">Log in</a>
          <a href="/products/unlock-the-vault" class="my-vault__button my-vault__button--secondary">Unlock the Vault</a>
        </div>
      </header>

    {% elsif has_vault_access == false %}
      <header class="my-vault__hero">
        <span class="my-vault__kicker">Digital Library</span>
        <h1 class="my-vault__title">My Vault</h1>
        <p class="my-vault__intro">
          You’re signed in, but full access is still locked. Read the free issue now or unlock the entire collection for one price.
        </p>
      </header>

      <div class="my-vault__panel">
        <h2 class="my-vault__panel-title">Vault locked</h2>
        <p class="my-vault__panel-copy">
          Get full access to the complete digital shelf for a one-time purchase of $3.
        </p>

        <div class="my-vault__actions">
          <a href="/products/unlock-the-vault" class="my-vault__button my-vault__button--primary">Unlock the Vault</a>
          <a href="/products/astroflush-1" class="my-vault__button my-vault__button--secondary">Read AstroFlush #1 Free</a>
        </div>
      </div>

      {% if comics_collection and comics_collection.products_count > 0 %}
        {% assign free_issue_count = 0 %}

        {% for product in comics_collection.products %}
          {% if product.handle == 'astroflush-1' %}
            {% assign free_issue_count = free_issue_count | plus: 1 %}
          {% endif %}
        {% endfor %}

        {% if free_issue_count > 0 %}
          <div class="my-vault__grid">
            {% for product in comics_collection.products %}
              {% if product.handle == 'astroflush-1' %}
                {% assign reader_url = product.metafields.custom.reader_url | default: product.url %}
                {% assign image_alt = product.featured_image.alt | default: product.title %}

                <article class="my-vault__card">
                  <a href="{{ reader_url }}" class="my-vault__image-link" aria-label="{{ product.title | escape }}">
                    <div class="my-vault__image-wrap">
                      {% if product.featured_image %}
                        <img
                          src="{{ product.featured_image | image_url: width: 900 }}"
                          alt="{{ image_alt | escape }}"
                          loading="lazy"
                          width="{{ product.featured_image.width }}"
                          height="{{ product.featured_image.height }}"
                          class="my-vault__image"
                        >
                      {% else %}
                        <div class="my-vault__image my-vault__image--placeholder"></div>
                      {% endif %}
                    </div>
                  </a>

                  <div class="my-vault__card-body">
                    <div class="my-vault__card-top">
                      <span class="my-vault__badge">Free Issue</span>
                    </div>

                    <h3 class="my-vault__card-title">{{ product.title }}</h3>

                    {% if product.description != blank %}
                      <p class="my-vault__card-copy">
                        {{ product.description | strip_html | truncate: 90 }}
                      </p>
                    {% else %}
                      <p class="my-vault__card-copy">
                        Start with the free issue and step into the world of BlackHole Magazine.
                      </p>
                    {% endif %}

                    <div class="my-vault__card-actions">
                      <a href="{{ reader_url }}" class="my-vault__button my-vault__button--primary my-vault__button--small">Read Free</a>
                      <a href="{{ product.url }}" class="my-vault__button my-vault__button--ghost my-vault__button--small">Details</a>
                    </div>
                  </div>
                </article>
              {% endif %}
            {% endfor %}
          </div>
        {% else %}
          <div class="my-vault__empty">
            <h2 class="my-vault__empty-title">Free issue coming soon</h2>
            <p class="my-vault__empty-copy">
              The Vault is still locked, and the free issue is not available yet. You can still unlock the full collection now.
            </p>
          </div>
        {% endif %}
      {% endif %}

    {% else %}
      <header class="my-vault__hero">
        <span class="my-vault__kicker">Unlocked Access</span>
        <h1 class="my-vault__title">My Vault</h1>
        <p class="my-vault__intro">
          Your library is open. Pick an issue and jump straight into the reader.
        </p>
      </header>

      {% if comics_collection and comics_collection.products_count > 0 %}
        {% assign vault_item_count = 0 %}

        {% for product in comics_collection.products %}
          {% if product.handle != 'unlock-the-vault' %}
            {% assign vault_item_count = vault_item_count | plus: 1 %}
          {% endif %}
        {% endfor %}

        {% if vault_item_count > 0 %}
          <div class="my-vault__grid">
            {% for product in comics_collection.products %}
              {% if product.handle != 'unlock-the-vault' %}
                {% assign reader_url = product.metafields.custom.reader_url | default: product.url %}
                {% assign image_alt = product.featured_image.alt | default: product.title %}

                <article class="my-vault__card">
                  <a href="{{ reader_url }}" class="my-vault__image-link" aria-label="{{ product.title | escape }}">
                    <div class="my-vault__image-wrap">
                      {% if product.featured_image %}
                        <img
                          src="{{ product.featured_image | image_url: width: 900 }}"
                          alt="{{ image_alt | escape }}"
                          loading="lazy"
                          width="{{ product.featured_image.width }}"
                          height="{{ product.featured_image.height }}"
                          class="my-vault__image"
                        >
                      {% else %}
                        <div class="my-vault__image my-vault__image--placeholder"></div>
                      {% endif %}
                    </div>
                  </a>

                  <div class="my-vault__card-body">
                    <div class="my-vault__card-top">
                      {% if product.handle == 'astroflush-1' %}
                        <span class="my-vault__badge">Free Issue</span>
                      {% else %}
                        <span class="my-vault__badge">In Vault</span>
                      {% endif %}
                    </div>

                    <h3 class="my-vault__card-title">{{ product.title }}</h3>

                    {% if product.description != blank %}
                      <p class="my-vault__card-copy">
                        {{ product.description | strip_html | truncate: 90 }}
                      </p>
                    {% else %}
                      <p class="my-vault__card-copy">
                        Open the issue and continue reading inside the reader.
                      </p>
                    {% endif %}

                    <div class="my-vault__card-actions">
                      <a href="{{ reader_url }}" class="my-vault__button my-vault__button--primary my-vault__button--small">Read Now</a>
                      <a href="{{ product.url }}" class="my-vault__button my-vault__button--ghost my-vault__button--small">Details</a>
                    </div>
                  </div>
                </article>
              {% endif %}
            {% endfor %}
          </div>
        {% else %}
          <div class="my-vault__empty">
            <h2 class="my-vault__empty-title">New issues will appear here</h2>
            <p class="my-vault__empty-copy">
              Your Vault is active. As new comics are added, they’ll show up here automatically.
            </p>
          </div>
        {% endif %}
      {% else %}
        <div class="my-vault__empty">
          <h2 class="my-vault__empty-title">New issues will appear here</h2>
          <p class="my-vault__empty-copy">
            Your Vault is active. As new comics are added, they’ll show up here automatically.
          </p>
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .my-vault {
    --vault-bg: #0a0a0b;
    --vault-panel: #111214;
    --vault-panel-2: #17181b;
    --vault-border: rgba(255, 255, 255, 0.1);
    --vault-border-strong: rgba(255, 255, 255, 0.18);
    --vault-text: #f5f5f2;
    --vault-muted: rgba(245, 245, 242, 0.68);
    --vault-soft: rgba(245, 245, 242, 0.48);
    --vault-accent: #f5f5f2;
    --vault-radius: 20px;
    --vault-radius-sm: 14px;
    --vault-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    background: var(--vault-bg);
    color: var(--vault-text);
    padding-top: 28px;
    padding-bottom: 56px;
  }

  .my-vault__inner {
    max-width: 1240px;
    margin: 0 auto;
  }

  .my-vault__hero {
    padding: 12px 0 26px;
  }

  .my-vault__kicker {
    display: inline-block;
    margin: 0 0 10px;
    font-size: 11px;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--vault-soft);
  }

  .my-vault__title {
    margin: 0;
    font-size: clamp(30px, 6vw, 56px);
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--vault-text);
  }

  .my-vault__intro {
    max-width: 700px;
    margin: 14px 0 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--vault-muted);
  }

  .my-vault__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 20px;
  }

  .my-vault__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.01em;
    transition: transform 0.18s ease, opacity 0.18s ease, background 0.18s ease, border-color 0.18s ease;
  }

  .my-vault__button:hover {
    transform: translateY(-1px);
  }

  .my-vault__button--primary {
    background: var(--vault-accent);
    color: #0a0a0b;
    border: 1px solid var(--vault-accent);
  }

  .my-vault__button--secondary {
    background: transparent;
    color: var(--vault-text);
    border: 1px solid var(--vault-border-strong);
  }

  .my-vault__button--ghost {
    background: rgba(255, 255, 255, 0.04);
    color: var(--vault-text);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .my-vault__button--small {
    min-height: 40px;
    padding-inline: 14px;
    font-size: 13px;
  }

  .my-vault__panel {
    margin-top: 8px;
    padding: 22px;
    border-radius: var(--vault-radius);
    border: 1px solid var(--vault-border);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0)), var(--vault-panel);
    box-shadow: var(--vault-shadow);
  }

  .my-vault__panel-title {
    margin: 0 0 8px;
    font-size: 22px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--vault-text);
  }

  .my-vault__panel-copy {
    max-width: 720px;
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--vault-muted);
  }

  .my-vault__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 24px;
  }

  .my-vault__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border-radius: 18px;
    border: 1px solid var(--vault-border);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.025), rgba(255, 255, 255, 0)), var(--vault-panel-2);
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .my-vault__card:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.16);
    box-shadow: 0 18px 38px rgba(0, 0, 0, 0.28);
  }

  .my-vault__image-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .my-vault__image-wrap {
    position: relative;
    aspect-ratio: 0.72;
    overflow: hidden;
    background: #0d0d0f;
  }

  .my-vault__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .my-vault__image--placeholder {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0));
  }

  .my-vault__card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 10px;
    padding: 14px;
  }

  .my-vault__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .my-vault__badge {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 0 9px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
    color: var(--vault-soft);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .my-vault__card-title {
    margin: 0;
    font-size: 17px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--vault-text);
  }

  .my-vault__card-copy {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    color: var(--vault-muted);
  }

  .my-vault__card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
    padding-top: 4px;
  }

  .my-vault__empty {
    display: grid;
    gap: 14px;
    padding: 24px;
    border-radius: var(--vault-radius);
    border: 1px dashed rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.02);
    margin-top: 22px;
  }

  .my-vault__empty-title {
    margin: 0;
    font-size: 20px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--vault-text);
  }

  .my-vault__empty-copy {
    margin: 0;
    max-width: 720px;
    font-size: 15px;
    line-height: 1.65;
    color: var(--vault-muted);
  }
  @media screen and (max-width: 749px) {
  .my-vault {
    padding-left: 12px;
    padding-right: 12px;
  }

  .my-vault__actions,
  .my-vault__card-actions {
    flex-direction: column;
  }

  .my-vault__actions .my-vault__button,
  .my-vault__card-actions .my-vault__button {
    width: 100%;
  }
}

  @media screen and (min-width: 750px) {
    .my-vault {
      padding-top: 40px;
      padding-bottom: 72px;
    }

    .my-vault__panel {
      padding: 28px;
    }

    .my-vault__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
    }

    .my-vault__card-body {
      padding: 16px;
    }
  }

  @media screen and (min-width: 1100px) {
    .my-vault__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .my-vault__actions,
    .my-vault__card-actions {
      flex-direction: column;
    }

    .my-vault__actions .my-vault__button,
    .my-vault__card-actions .my-vault__button {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "My Vault library",
  "settings": [],
  "presets": [
    {
      "name": "My Vault library"
    }
  ]
}
{% endschema %}